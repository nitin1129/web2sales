# Web app — frontend env vars (read by Vite at BUILD time).
# Copy to apps/web/.env for local dev, or set in your host's
# environment-variables UI for prod.
#
# IMPORTANT: Vite bakes these into the bundle at BUILD time. Always
# trigger a rebuild after changing any value. All keys MUST start
# with VITE_ to be exposed to the browser.

# Where the Express API is reachable (no trailing slash).
# Local dev default if unset: http://localhost:3001
# Production example: https://api.web2sales.in
VITE_API_URL=http://localhost:3001
